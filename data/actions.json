{
  "move": {
    "targetingType": "spatial",
    "componentBinding": {
      "roles": ["spatial"],
      "spatialRole": "source",
      "description": "Movement actions bind to components with Movement traits. The selected spatial component provides the move speed value."
    },
    "requirements": [
      {
        "trait": "Movement",
        "stat": "move",
        "minValue": 5
      }
    ],
    "consequences": [
      {
        "type": "deltaSpatial",
        "params": { "speed": ":Movement.move" }
      }
    ],
    "failureConsequences": [
      {
        "type": "log",
        "level": "warn",
        "message": "Action 'move' failed - requirement not met"
      }
    ]
  },
  "dash": {
    "targetingType": "spatial",
    "componentBinding": {
      "roles": ["spatial", "self_target"],
      "spatialRole": "source",
      "selfTargetRole": "self_target",
      "description": "Dash binds to a Movement component as source (provides speed) and a Physical component as self_target (absorbs durability cost). The selected spatial component determines which leg/arm drives the dash."
    },
    "requirements": [
      {
        "trait": "Movement",
        "stat": "move",
        "minValue": 5
      },
      {
        "trait": "Physical",
        "stat": "durability",
        "minValue": 30
      }
    ],
    "consequences": [
      {
        "type": "deltaSpatial",
        "params": { "speed": ":Movement.move*2" }
      },
      {
        "type": "updateComponentStatDelta",
        "params": { "trait": "Physical", "stat": "durability", "value": -5 }
      }
    ],
    "failureConsequences": [
      {
        "type": "log",
        "level": "warn",
        "message": "Action 'dash' failed - requirement not met"
      }
    ]
  },
  "selfHeal": {
    "targetingType": "self_target",
    "componentBinding": {
      "roles": ["self_target"],
      "selfTargetRole": "self_target",
      "description": "Self-heal binds to a Physical component as self_target. The selected component receives the durability restoration."
    },
    "requirements": [
      {
        "trait": "Movement",
        "stat": "move",
        "minValue": 1
      },
      {
        "trait": "Physical",
        "stat": "durability",
        "minValue": 1
      }
    ],
    "consequences": [
      {
        "type": "updateComponentStatDelta",
        "params": { "trait": "Physical", "stat": "durability", "value": 10 }
      }
    ],
    "failureConsequences": [
      {
        "type": "log",
        "level": "warn",
        "message": "Action 'selfHeal' failed - requirement not met"
      }
    ]
  },
  "droid punch": {
    "targetingType": "component",
    "range": 100,
    "componentBinding": {
      "roles": ["source", "target"],
      "sourceRole": "source",
      "targetRole": "target",
      "description": "Punch binds to a Physical component as source (provides strength for damage) and a target component on the enemy (receives durability damage). The attacker's component is selected first, then the target component is clicked on the map."
    },
    "requirements": [
      {
        "trait": "Physical",
        "stat": "strength",
        "minValue": 15
      }
    ],
    "consequences": [
      {
        "type": "damageComponent",
        "params": {
          "trait": "Physical",
          "stat": "durability",
          "value": "-:Physical.strength"
        }
      },
      {
        "type": "log",
        "level": "info",
        "message": "Droid performed a punch dealing :Physical.strength damage!"
      }
    ],
    "failureConsequences": [
      {
        "type": "log",
        "level": "warn",
        "message": "Punch failed - strength too low"
      }
    ]
  },
  "grab": {
    "targetingType": "component",
    "range": 100,
    "componentBinding": {
      "roles": ["source", "target"],
      "sourceRole": "source",
      "targetRole": "target",
      "description": "Grab binds to a Physical component as source (hand) and an item entity as target. The item becomes a component of the entity. The hand suffers a strength debuff from carrying weight."
    },
    "requirements": [
      {
        "trait": "Physical",
        "stat": "strength",
        "minValue": 25
      }
    ],
    "consequences": [
      {
        "type": "grabItem",
        "params": {
          "debuff": { "trait": "Physical", "stat": "strength", "value": -5 }
        }
      },
      {
        "type": "log",
        "level": "info",
        "message": "Entity grabbed item — new capabilities unlocked!"
      }
    ],
    "failureConsequences": [
      {
        "type": "log",
        "level": "warn",
        "message": "Grab failed — item out of range or strength too low"
      }
    ]
  },
  "release": {
    "targetingType": "self_target",
    "componentBinding": {
      "roles": ["self_target"],
      "selfTargetRole": "self_target",
      "description": "Release is a self-targeting action that executes instantly when a grabbed item component is clicked. The item is dropped back into the world and strength is restored."
    },
    "requirements": [],
    "consequences": [
      {
        "type": "releaseItem",
        "params": {}
      },
      {
        "type": "log",
        "level": "info",
        "message": "Entity dropped the held item."
      }
    ],
    "failureConsequences": [
      {
        "type": "log",
        "level": "warn",
        "message": "Release failed — no item equipped"
      }
    ]
  },
  "cut": {
    "targetingType": "component",
    "range": 100,
    "componentBinding": {
      "roles": ["source", "target"],
      "sourceRole": "source",
      "targetRole": "target",
      "description": "Cut binds to a Physical component with sharpness as source (hand holding the knife) and a target component on the enemy (being cut). The knife's sharpness stat determines the damage dealt. Requires Physical.sharpness ≥ 20."
    },
    "requirements": [
      {
        "trait": "Physical",
        "stat": "sharpness",
        "minValue": 20
      }
    ],
    "consequences": [
      {
        "type": "damageComponent",
        "params": {
          "trait": "Physical",
          "stat": "durability",
          "value": "-:Physical.sharpness"
        }
      },
      {
        "type": "updateComponentStatDelta",
        "params": {
          "trait": "Physical",
          "stat": "sharpness",
          "value": -2
        }
      },
      {
        "type": "log",
        "level": "info",
        "message": "Entity used a knife to cut dealing :Physical.sharpness damage! Knife sharpness reduced by 2."
      }
    ],
    "failureConsequences": [
      {
        "type": "log",
        "level": "warn",
        "message": "Cut failed - sharpness too low"
      }
    ]
  },
  "grabToBackpack": {
    "targetingType": "component",
    "range": 100,
    "componentBinding": {
      "roles": ["source", "target"],
      "sourceRole": "self_target",
      "targetRole": "target",
      "description": "Grab binds to the droidBackpack component as source and an item entity as target. The item is stored in the backpack instead of the hand. The backpack's Physical.volume determines total storage capacity."
    },
    "requirements": [
      {
        "trait": "Physical",
        "stat": "volume",
        "minValue": 5
      }
    ],
    "consequences": [
      {
        "type": "grabToBackpack",
        "params": {}
      },
      {
        "type": "log",
        "level": "info",
        "message": "Item stored in droid backpack."
      }
    ],
    "failureConsequences": [
      {
        "type": "log",
        "level": "warn",
        "message": "Grab to backpack failed — item out of range or backpack full"
      }
    ]
  },
  "dropAll": {
    "targetingType": "self_target",
    "componentBinding": {
      "roles": ["self_target"],
      "selfTargetRole": "self_target",
      "description": "Drop all is a self-targeting action that executes instantly when clicked. All grabbed items and backpack items are dropped into the world."
    },
    "requirements": [],
    "consequences": [
      {
        "type": "dropAll",
        "params": {}
      },
      {
        "type": "log",
        "level": "info",
        "message": "All items dropped."
      }
    ],
    "failureConsequences": [
      {
        "type": "log",
        "level": "warn",
        "message": "Drop all failed — nothing to drop"
      }
    ]
  }
}
